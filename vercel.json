{
  "buildCommand": "node scripts/build-public.js",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/((?!js/|css/|assets/|shared/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
    },
    {
      "source": "/shared/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600" }]
    }
  ]
}
